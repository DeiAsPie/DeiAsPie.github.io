{
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@playwright/test": "^1.55.1",
    "@tailwindcss/cli": "^4.1.16",
    "@tailwindcss/typography": "^0.5.19",
    "axe-core": "^4.11.1",
    "eslint": "^9.36.0",
    "eslint-plugin-security": "^4.0.0",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "prettier": "^3.6.2",
    "prettier-plugin-go-template": "^0.0.15",
    "tailwindcss": "^4.1.13"
  },
  "lint-staged": {
    "*.{js,mjs}": "eslint --max-warnings=0"
  },
  "name": "DeiAsPie.github.io",
  "private": true,
  "scripts": {
    "audit:artifacts": "python3 scripts/audit_artifacts.py",
    "audit:artifacts:fix": "python3 scripts/audit_artifacts.py --fix",
    "axe": "AXE_URLS='http://localhost:8080/' node scripts/run_axe.mjs",
    "build": "hugo --minify --gc",
    "build:css": "tailwindcss -i ./assets/css/main.css -o ./assets/gen/tailwind.css --minify",
    "dev": "hugo server --disableFastRender",
    "format": "prettier --write .",
    "lint": "eslint assets/js --max-warnings=0",
    "lint:content": "node scripts/check_content_quality.js",
    "lint:content:report": "node scripts/check_content_quality.js --report",
    "lint:fix": "eslint assets/js --fix",
    "lint:markdown": "markdownlint-cli2 '**/*.md'",
    "lint:markdown:fix": "markdownlint-cli2 --fix '**/*.md'",
    "prebuild": "npm run build:css",
    "prepare": "husky",
    "size:css": "node -e \"const fs=require('fs');const b=fs.statSync('./assets/gen/tailwind.css').size;console.log((b/1024).toFixed(1)+' KiB');\"",
    "size:images": "node scripts/check_image_budgets.js --report",
    "size:images:check": "IMAGE_BUDGET_KIB=400 node scripts/check_image_budgets.js",
    "test": "pytest -q",
    "test:e2e": "playwright test --project=chromium --project=firefox",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:e2e:ui": "playwright test --ui",
    "test:smoke": "playwright test --project=smoke-tests"
  },
  "version": "3.2.0"
}
